PORT=3000
MONGODB_URI=mongodb://localhost:27017/execution-engine
SANDBOX_CPU=2
SANDBOX_MEMORY=1024m
SANDBOX_TIMEOUT_MS=5000
REDIS_HOST = 127.0.0.1
REDIS_PORT = 6379
REDIS_PASSWORD = 12345
JAVA_POOL_SIZE=5
POOL_SIZE=5

# Dynamic pool autoscaling
# MIN_POOL_SIZE: containers kept alive even when idle (per language, always warm)
# MAX_POOL_SIZE: hard ceiling — no more containers created beyond this
# SCALE_DOWN_INTERVAL_MS: how often the idle watcher checks queue depth (ms)
MIN_POOL_SIZE=3
MAX_POOL_SIZE=20
SCALE_DOWN_INTERVAL_MS=60000

# Admin portal — change this before deploying to production
ADMIN_API_KEY=change-me-before-deploying